    {
      "claimId": "claim-gayer-anderson-museum-story-1",
      "placeSlug": "gayer-anderson-museum",
      "storySlug": "story-gayer-anderson-museum",
      "claimType": "story-chapter",
      "claimTextEn": "The museum occupies two connected historic houses beside Ibn Tulun Mosque. Courtyards, reception halls, mashrabiyas, and service routes reveal domestic architecture, while Gayer-Anderson’s twentieth-century residence added a separate museum layer. The interpretation must distinguish the older houses from the later collection and display choices.",
      "claimTextAr": "يشغل المتحف بيتين تاريخيين متصلين بجوار جامع ابن طولون. وتكشف الأفنية وقاعات الاستقبال والمشربيات ومسارات الخدمة عمارة السكن، بينما أضافت إقامة جاير أندرسون في القرن العشرين طبقة متحفية منفصلة. ويجب التمييز بين البيتين الأقدم والمجموعة وطرق العرض اللاحقة.",
      "sourceIds": [
        "src-egy-gayer",
        "src-egy-historic",
        "src-media-gayer"
      ],
      "certainty": "supported"
    },
