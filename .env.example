# Browser-safe Supabase project settings
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-publishable-key

# Server-only PostgreSQL session pooler URL
DATABASE_URL=postgresql://postgres.your-project-ref:your-password@aws-0-your-region.pooler.supabase.com:5432/postgres

# Existing Manus OAuth and storage configuration
VITE_APP_ID=your-manus-app-id
JWT_SECRET=replace-with-a-long-random-secret
OAUTH_SERVER_URL=https://your-oauth-server.example.com
OWNER_OPEN_ID=your-owner-open-id
BUILT_IN_FORGE_API_URL=https://your-forge-api.example.com
BUILT_IN_FORGE_API_KEY=your-server-only-forge-key

NODE_ENV=development
PORT=3000
